2025-08-01T14:25:39.144140262Z function (input) 
2025-08-01T14:25:39.144149836Z {
2025-08-01T14:25:39.144152442Z     print("Create supporting variable ")
2025-08-01T14:25:39.144154355Z     if (all(c("sub_bin_asthma_recent", "sub_bin_copd_ever") %in% 
2025-08-01T14:25:39.144156131Z         names(input))) {
2025-08-01T14:25:39.144157623Z         input$sup_bin_preex <- (input$sub_bin_asthma_recent | 
2025-08-01T14:25:39.144159276Z             input$sub_bin_copd_ever)
2025-08-01T14:25:39.144160760Z     }
2025-08-01T14:25:39.144162271Z     else {
2025-08-01T14:25:39.144163766Z         warning("One or both variables ('sub_bin_asthma_recent', 'sub_bin_copd_ever') are missing. sup_bin_preex will not be created.")
2025-08-01T14:25:39.144170042Z     }
2025-08-01T14:25:39.144172028Z     print("Handle missing values in cov_cat_sex")
2025-08-01T14:25:39.144173704Z     if ("cov_cat_sex" %in% names(input)) {
2025-08-01T14:25:39.144175318Z         input$cov_cat_sex <- if_else(input$cov_cat_sex %in% c("male", 
2025-08-01T14:25:39.144177014Z             "female"), input$cov_cat_sex, "missing")
2025-08-01T14:25:39.144178691Z         if ("missing" %in% unique(input$cov_cat_sex)) {
2025-08-01T14:25:39.144180312Z             stop("cov_cat_sex contains missing values.")
