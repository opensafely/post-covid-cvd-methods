2025-08-01T14:25:39.142990303Z function (df, cohort) 
2025-08-01T14:25:39.143030840Z {
2025-08-01T14:25:39.143032296Z     set.seed(1)
2025-08-01T14:25:39.143033421Z     pandemic_start <- as.Date(study_dates$pandemic_start, format = "%Y-%m-%d", 
2025-08-01T14:25:39.143034825Z         origin = "1970-01-01")
2025-08-01T14:25:39.143035865Z     if (cohort == "vax") {
2025-08-01T14:25:39.143037014Z         df <- df %>% mutate(vax_date_Pfizer_1 = as.Date(vax_date_eligible) + 
2025-08-01T14:25:39.143038296Z             days(round(rnorm(nrow(.), mean = 10, sd = 3))), vax_date_AstraZeneca_1 = as.Date(vax_date_eligible) + 
2025-08-01T14:25:39.143039492Z             days(round(rnorm(nrow(.), mean = 10, sd = 3))), vax_date_Moderna_1 = as.Date(vax_date_eligible) + 
2025-08-01T14:25:39.143040550Z             days(round(rnorm(nrow(.), mean = 10, sd = 3)))) %>% 
2025-08-01T14:25:39.143041617Z             mutate(vaccine_1_type = sample(x = c("Pfizer", "AstraZeneca", 
2025-08-01T14:25:39.143042814Z                 "Moderna", "None"), size = nrow(.), replace = TRUE, 
2025-08-01T14:25:39.143043985Z                 prob = c(0.4, 0.4, 0.05, 0.1)), missing_pfizer_2 = rbernoulli(nrow(.), 
2025-08-01T14:25:39.143045046Z                 p = 0.05), missing_az_2 = rbernoulli(nrow(.), 
2025-08-01T14:25:39.143046061Z                 p = 0.05), missing_moderna_2 = rbernoulli(nrow(.), 
2025-08-01T14:25:39.143047327Z                 p = 0.05), missing_pfizer_3 = rbernoulli(nrow(.), 
2025-08-01T14:25:39.143048388Z                 p = 0.9), missing_az_3 = rbernoulli(nrow(.), 
2025-08-01T14:25:39.143049400Z                 p = 0.9), missing_moderna_3 = rbernoulli(nrow(.), 
2025-08-01T14:25:39.143050442Z                 p = 0.9)) %>% mutate(across(vax_date_Pfizer_1, 
2025-08-01T14:25:39.143051511Z             ~if_else(vaccine_1_type %in% "Pfizer", .x, NA_Date_))) %>% 
2025-08-01T14:25:39.143052575Z             mutate(across(vax_date_AstraZeneca_1, ~if_else(vaccine_1_type %in% 
2025-08-01T14:25:39.143053597Z                 "AstraZeneca", .x, NA_Date_))) %>% mutate(across(vax_date_Moderna_1, 
2025-08-01T14:25:39.143054706Z             ~if_else(vaccine_1_type %in% "Moderna", .x, NA_Date_))) %>% 
2025-08-01T14:25:39.143055796Z             mutate(across(matches("vax_date\\w+_1"), ~if_else(vaccine_1_type %in% 
2025-08-01T14:25:39.143057020Z                 "None", NA_Date_, .x))) %>% mutate(vax_date_covid_1 = pmin(vax_date_Pfizer_1, 
2025-08-01T14:25:39.143058152Z             vax_date_AstraZeneca_1, vax_date_Moderna_1, na.rm = T)) %>% 
2025-08-01T14:25:39.143059183Z             mutate(vax_date_Pfizer_2 = vax_date_Pfizer_1 + days(round(rnorm(nrow(.), 
2025-08-01T14:25:39.143060187Z                 mean = 10 * 7, sd = 3))), vax_date_AstraZeneca_2 = vax_date_AstraZeneca_1 + 
2025-08-01T14:25:39.143061194Z                 days(round(rnorm(nrow(.), mean = 10 * 7, sd = 3))), 
2025-08-01T14:25:39.143062988Z                 vax_date_Moderna_2 = vax_date_Moderna_1 + days(round(rnorm(nrow(.), 
2025-08-01T14:25:39.143065845Z                   mean = 10 * 7, sd = 3))), ) %>% mutate(vaccine_2_type = ifelse(runif(nrow(df), 
2025-08-01T14:25:39.143066925Z             0, 1) > 0.95 & vaccine_1_type != "None", sample(x = c("Pfizer", 
2025-08-01T14:25:39.143068223Z             "AstraZeneca", "Moderna", "None"), size = nrow(.), 
2025-08-01T14:25:39.143069379Z             replace = TRUE, prob = c(0.4, 0.4, 0.05, 0.1)), vaccine_1_type)) %>% 
2025-08-01T14:25:39.143070385Z             mutate(across(vax_date_Pfizer_2, ~if_else(vaccine_2_type %in% 
2025-08-01T14:25:39.143071378Z                 "Pfizer", .x, NA_Date_))) %>% mutate(across(vax_date_AstraZeneca_2, 
2025-08-01T14:25:39.143072503Z             ~if_else(vaccine_2_type %in% "AstraZeneca", .x, NA_Date_))) %>% 
2025-08-01T14:25:39.143073615Z             mutate(across(vax_date_Moderna_2, ~if_else(vaccine_2_type %in% 
2025-08-01T14:25:39.143074607Z                 "Moderna", .x, NA_Date_))) %>% mutate(across(matches("vax_date\\w+_2"), 
2025-08-01T14:25:39.143075779Z             ~if_else(vaccine_2_type %in% "None", NA_Date_, .x))) %>% 
2025-08-01T14:25:39.143076909Z             mutate(across(vax_date_Pfizer_2, ~if_else(missing_pfizer_2, 
2025-08-01T14:25:39.143077878Z                 NA_Date_, .x))) %>% mutate(across(vax_date_AstraZeneca_2, 
2025-08-01T14:25:39.143078945Z             ~if_else(missing_az_2, NA_Date_, .x))) %>% mutate(across(vax_date_Moderna_2, 
2025-08-01T14:25:39.143079996Z             ~if_else(missing_moderna_2, NA_Date_, .x))) %>% mutate(vax_date_covid_2 = pmin(vax_date_Pfizer_2, 
2025-08-01T14:25:39.143081057Z             vax_date_AstraZeneca_2, vax_date_Moderna_2, na.rm = T)) %>% 
2025-08-01T14:25:39.143082076Z             mutate(vaccine_3_type = ifelse(vaccine_2_type != 
