2025-08-01T14:25:39.143182218Z function (cohort, describe) 
2025-08-01T14:25:39.143183185Z {
2025-08-01T14:25:39.143184065Z     print("Get column names")
2025-08-01T14:25:39.143185072Z     file_path <- paste0("output/dataset_definition/input_", cohort, 
2025-08-01T14:25:39.143186182Z         ".csv.gz")
2025-08-01T14:25:39.143187149Z     all_cols <- fread(file_path, header = TRUE, sep = ",", nrows = 0, 
2025-08-01T14:25:39.143188304Z         stringsAsFactors = FALSE) %>% names()
2025-08-01T14:25:39.143189336Z     message("Column names found")
2025-08-01T14:25:39.143190362Z     print(all_cols)
2025-08-01T14:25:39.143191307Z     print("Define column classes")
2025-08-01T14:25:39.143192264Z     cat_cols <- c("patient_id", grep("_cat", all_cols, value = TRUE))
2025-08-01T14:25:39.143193414Z     bin_cols <- c(grep("_bin", all_cols, value = TRUE))
2025-08-01T14:25:39.143195835Z     num_cols <- c(grep("_num", all_cols, value = TRUE), grep("vax_jcvi_age_", 
2025-08-01T14:25:39.143196951Z         all_cols, value = TRUE))
2025-08-01T14:25:39.143197918Z     date_cols <- grep("_date", all_cols, value = TRUE)
2025-08-01T14:25:39.143198996Z     message("Column classes identified")
2025-08-01T14:25:39.143200034Z     col_classes <- setNames(c(rep("c", length(cat_cols)), rep("l", 
2025-08-01T14:25:39.143201318Z         length(bin_cols)), rep("d", length(num_cols)), rep("D", 
2025-08-01T14:25:39.143202385Z         length(date_cols))), all_cols[match(c(cat_cols, bin_cols, 
2025-08-01T14:25:39.143203401Z         num_cols, date_cols), all_cols)])
2025-08-01T14:25:39.143204334Z     message("Column classes defined")
2025-08-01T14:25:39.143205343Z     print("Load cohort dataset")
2025-08-01T14:25:39.143206522Z     input <- read_csv(file_path, col_types = col_classes)
2025-08-01T14:25:39.143207538Z     message(paste0("Dataset has been read successfully with N = ", 
2025-08-01T14:25:39.143208627Z         nrow(input), " rows"))
2025-08-01T14:25:39.143209599Z     print("Modify dummy data")
2025-08-01T14:25:39.143210571Z     if (Sys.getenv("OPENSAFELY_BACKEND") %in% c("", "expectations")) {
2025-08-01T14:25:39.143211710Z         input <- modify_dummy(input, cohort)
2025-08-01T14:25:39.143212690Z     }
2025-08-01T14:25:39.143213607Z     print("Format dataset columns")
2025-08-01T14:25:39.143214589Z     input <- input %>% mutate(across(all_of(date_cols), ~floor_date(as.Date(., 
2025-08-01T14:25:39.143215677Z         format = "%Y-%m-%d"), unit = "days")), across(contains("_birth_year"), 
2025-08-01T14:25:39.143216813Z         ~as.numeric(.)), across(all_of(num_cols), ~as.numeric(.)), 
2025-08-01T14:25:39.143217832Z         across(all_of(cat_cols), ~as.character(.)))
2025-08-01T14:25:39.143218786Z     print("Describe data")
2025-08-01T14:25:39.143219744Z     if (isTRUE(describe)) {
2025-08-01T14:25:39.143220696Z         describe_data(df = input, name = paste0(cohort, "_raw"))
2025-08-01T14:25:39.143221780Z     }
2025-08-01T14:25:39.143222635Z     print("Remove records with missing patient id")
2025-08-01T14:25:39.143223625Z     input <- input[!is.na(input$patient_id), ]
2025-08-01T14:25:39.143224610Z     message("All records with valid patient IDs retained.")
2025-08-01T14:25:39.143225654Z     print("Make Venn diagram input dataset")
2025-08-01T14:25:39.143226651Z     venn <- input %>% select(starts_with(c("patient_id", "tmp_out_date", 
2025-08-01T14:25:39.143227741Z         "out_date")))
2025-08-01T14:25:39.143228678Z     print("Restrict columns")
2025-08-01T14:25:39.143230834Z     input <- input %>% select(patient_id, starts_with("index_date"), 
2025-08-01T14:25:39.143231936Z         starts_with("end_date_"), starts_with("sub_"), starts_with("exp_"), 
2025-08-01T14:25:39.143233048Z         starts_with("out_"), starts_with("cov_"), starts_with("inex_"), 
2025-08-01T14:25:39.143234234Z         starts_with("cens_"), starts_with("qa_"), starts_with("strat_"), 
2025-08-01T14:25:39.143235428Z         starts_with("vax_date_"), starts_with("vax_cat_"))
2025-08-01T14:25:39.143236509Z     print("Describe files")
2025-08-01T14:25:39.143237486Z     if (isTRUE(describe)) {
2025-08-01T14:25:39.143238445Z         describe_data(df = venn, name = paste0(cohort, "_venn"))
2025-08-01T14:25:39.143239494Z         describe_data(df = input, name = paste0(cohort, "_preprocessed"))
2025-08-01T14:25:39.143240553Z     }
2025-08-01T14:25:39.143241453Z     print("Return data")
2025-08-01T14:25:39.143242432Z     return(list(venn = venn, input = input))
2025-08-01T14:25:39.143243401Z }
2025-08-01T14:25:39.143244273Z 
