2025-08-01T14:25:39.141434417Z function (input, flow, cohort, vax1_earliest, mixed_vax_threshold, 
2025-08-01T14:25:39.141456274Z     delta_date, lcd_date) 
2025-08-01T14:25:39.141458715Z {
2025-08-01T14:25:39.141460319Z     print("Apply inclusion criteria to all cohorts")
2025-08-01T14:25:39.141461966Z     input <- subset(input, inex_bin_alive == TRUE)
2025-08-01T14:25:39.141463838Z     flow[nrow(flow) + 1, ] <- c("Inclusion criteria: Alive at index", 
2025-08-01T14:25:39.141475652Z         nrow(input))
2025-08-01T14:25:39.141477511Z     print(flow[nrow(flow), ])
2025-08-01T14:25:39.141479164Z     input <- subset(input, cov_num_age >= 18)
2025-08-01T14:25:39.141480772Z     flow[nrow(flow) + 1, ] <- c("Inclusion criteria: Known age 18 or over at index", 
2025-08-01T14:25:39.141482433Z         nrow(input))
2025-08-01T14:25:39.141483845Z     print(flow[nrow(flow), ])
2025-08-01T14:25:39.141485328Z     input <- subset(input, cov_num_age <= 110)
2025-08-01T14:25:39.141486918Z     flow[nrow(flow) + 1, ] <- c("Inclusion criteria: Known age 110 or under at index", 
2025-08-01T14:25:39.141488480Z         nrow(input))
2025-08-01T14:25:39.141489916Z     print(flow[nrow(flow), ])
2025-08-01T14:25:39.141491354Z     input <- subset(input, cov_cat_sex %in% c("female", "male"))
2025-08-01T14:25:39.141493066Z     flow[nrow(flow) + 1, ] <- c("Inclusion criteria: Known sex, recorded as male or female, at index", 
2025-08-01T14:25:39.141494677Z         nrow(input))
2025-08-01T14:25:39.141496014Z     print(flow[nrow(flow), ])
2025-08-01T14:25:39.141497397Z     input <- subset(input, cov_cat_imd %in% c("1 (most deprived)", 
2025-08-01T14:25:39.141498936Z         "2", "3", "4", "5 (least deprived)"))
2025-08-01T14:25:39.141500611Z     flow[nrow(flow) + 1, ] <- c("Inclusion criteria: Known IMD at index", 
2025-08-01T14:25:39.141502122Z         nrow(input))
2025-08-01T14:25:39.141503498Z     print(flow[nrow(flow), ])
2025-08-01T14:25:39.141504871Z     input <- subset(input, strat_cat_region %in% c("East", "East Midlands", 
2025-08-01T14:25:39.141506479Z         "London", "North East", "North West", "South East", "South West", 
2025-08-01T14:25:39.141508100Z         "West Midlands", "Yorkshire and The Humber"))
2025-08-01T14:25:39.141509687Z     flow[nrow(flow) + 1, ] <- c("Inclusion criteria: Known region at index", 
2025-08-01T14:25:39.141511234Z         nrow(input))
2025-08-01T14:25:39.141512586Z     print(flow[nrow(flow), ])
2025-08-01T14:25:39.141513951Z     input <- subset(input, inex_bin_6m_reg == TRUE)
2025-08-01T14:25:39.141515489Z     flow[nrow(flow) + 1, ] <- c("Inclusion criteria: Continuous registration with the same practice for at least six months up to and including the index date", 
2025-08-01T14:25:39.141517163Z         nrow(input))
2025-08-01T14:25:39.141518527Z     print(flow[nrow(flow), ])
2025-08-01T14:25:39.141519898Z     input <- subset(input, index_date <= end_date_exposure)
2025-08-01T14:25:39.141521406Z     flow[nrow(flow) + 1, ] <- c("Inclusion criteria: Index date is before cohort end date", 
2025-08-01T14:25:39.141522913Z         nrow(input))
2025-08-01T14:25:39.141524283Z     print(flow[nrow(flow), ])
2025-08-01T14:25:39.141527478Z     print("Apply cohort specific inclusion criteria")
2025-08-01T14:25:39.141529272Z     if (cohort == "vax") {
2025-08-01T14:25:39.141531945Z         input <- subset(input, !is.na(vax_date_covid_1) & !is.na(vax_date_covid_2) & 
2025-08-01T14:25:39.141533724Z             vax_date_covid_2 < lcd_date)
2025-08-01T14:25:39.141535240Z         flow[nrow(flow) + 1, ] <- c("Inclusion criteria: Record of two vaccination doses prior to the study end date", 
2025-08-01T14:25:39.141536918Z             nrow(input))
2025-08-01T14:25:39.141538279Z         print(flow[nrow(flow), ])
2025-08-01T14:25:39.141539668Z         input <- subset(input, (is.na(vax_date_covid_1) | vax_date_covid_1 >= 
2025-08-01T14:25:39.141541187Z             vax1_earliest) & (is.na(vax_date_covid_2) | vax_date_covid_2 >= 
2025-08-01T14:25:39.141542753Z             vax1_earliest) & (is.na(vax_date_covid_3) | vax_date_covid_3 >= 
2025-08-01T14:25:39.141544262Z             vax1_earliest))
2025-08-01T14:25:39.141545651Z         flow[nrow(flow) + 1, ] <- c("Inclusion criteria: Did not receive a vaccination prior to 08-12-2020 (i.e., the start of the vaccination program)", 
2025-08-01T14:25:39.141547372Z             nrow(input))
2025-08-01T14:25:39.141548770Z         print(flow[nrow(flow), ])
2025-08-01T14:25:39.141554046Z         input <- subset(input, vax_date_covid_2 >= vax_date_covid_1)
2025-08-01T14:25:39.141555672Z         flow[nrow(flow) + 1, ] <- c("Inclusion criteria: Did not receive a second dose vaccination before their first dose vaccination", 
2025-08-01T14:25:39.141557335Z             nrow(input))
2025-08-01T14:25:39.141558777Z         print(flow[nrow(flow), ])
2025-08-01T14:25:39.141560180Z         input <- subset(input, (vax_date_covid_2 - vax_date_covid_1) >= 
2025-08-01T14:25:39.141561756Z             21)
2025-08-01T14:25:39.141563221Z         flow[nrow(flow) + 1, ] <- c("Inclusion criteria: Did not receive a second dose vaccination less than three weeks after their first dose", 
2025-08-01T14:25:39.141565025Z             nrow(input))
2025-08-01T14:25:39.141566430Z         print(flow[nrow(flow), ])
2025-08-01T14:25:39.141567867Z         input <- input %>% mutate(AZ_date = case_when(vax_date_AstraZeneca_1 < 
2025-08-01T14:25:39.141569464Z             mixed_vax_threshold ~ 1, vax_date_AstraZeneca_2 < 
2025-08-01T14:25:39.141570967Z             mixed_vax_threshold ~ 1, vax_date_AstraZeneca_3 < 
2025-08-01T14:25:39.141572548Z             mixed_vax_threshold ~ 1, TRUE ~ 0), Moderna_date = case_when(vax_date_Moderna_1 < 
2025-08-01T14:25:39.141574255Z             mixed_vax_threshold ~ 1, vax_date_Moderna_2 < mixed_vax_threshold ~ 
2025-08-01T14:25:39.141575760Z             1, vax_date_Moderna_3 < mixed_vax_threshold ~ 1, 
2025-08-01T14:25:39.141577229Z             TRUE ~ 0), Pfizer_date = case_when(vax_date_Pfizer_1 < 
2025-08-01T14:25:39.141580643Z             mixed_vax_threshold ~ 1, vax_date_Pfizer_2 < mixed_vax_threshold ~ 
2025-08-01T14:25:39.141582381Z             1, vax_date_Pfizer_3 < mixed_vax_threshold ~ 1, TRUE ~ 
2025-08-01T14:25:39.141584317Z             0)) %>% rowwise() %>% mutate(vax_mixed = sum(c_across(c(AZ_date, 
2025-08-01T14:25:39.141586022Z             Moderna_date, Pfizer_date)), na.rm = TRUE)) %>% ungroup() %>% 
2025-08-01T14:25:39.141587580Z             dplyr::filter(vax_mixed < 2) %>% select(-AZ_date, 
2025-08-01T14:25:39.141589081Z             -Moderna_date, -Pfizer_date, -vax_mixed)
2025-08-01T14:25:39.141590595Z         flow[nrow(flow) + 1, ] <- c("Inclusion criteria: Did not receive a mixed vaccine products before 07-05-2021", 
2025-08-01T14:25:39.141592225Z             nrow(input))
2025-08-01T14:25:39.141593597Z         print(flow[nrow(flow), ])
2025-08-01T14:25:39.141595012Z     }
2025-08-01T14:25:39.141596386Z     else if (cohort == "unvax") {
2025-08-01T14:25:39.141598407Z         input <- subset(input, (is.na(vax_date_covid_1) | vax_date_covid_1 >= 
2025-08-01T14:25:39.141599946Z             index_date) & (is.na(vax_date_covid_2) | vax_date_covid_2 >= 
2025-08-01T14:25:39.141601458Z             index_date) & (is.na(vax_date_covid_3) | vax_date_covid_3 >= 
2025-08-01T14:25:39.141602975Z             index_date))
2025-08-01T14:25:39.141604381Z         flow[nrow(flow) + 1, ] <- c("Inclusion criteria: Does not have a record of one or more vaccination prior to index date", 
2025-08-01T14:25:39.141606013Z             nrow(input))
2025-08-01T14:25:39.141607369Z         print(flow[nrow(flow), ])
2025-08-01T14:25:39.141608750Z         input <- subset(input, vax_cat_jcvi_group %in% c("01", 
2025-08-01T14:25:39.141610353Z             "02", "03", "04", "05", "06", "07", "08", "09", "10", 
2025-08-01T14:25:39.141612114Z             "11", "12"))
2025-08-01T14:25:39.141613552Z         flow[nrow(flow) + 1, ] <- c("Inclusion criteria: Not missing JCVI group", 
2025-08-01T14:25:39.141615088Z             nrow(input))
2025-08-01T14:25:39.141616480Z         print(flow[nrow(flow), ])
2025-08-01T14:25:39.141617898Z     }
2025-08-01T14:25:39.141619224Z     return(list(input = input, flow = flow))
2025-08-01T14:25:39.141620696Z }
