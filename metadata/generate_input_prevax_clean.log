2025-08-01T14:25:39.143361965Z function (input, flow, lcd_date) 
2025-08-01T14:25:39.143369374Z {
2025-08-01T14:25:39.143371480Z     print("Apply quality assurance to all cohorts")
2025-08-01T14:25:39.143373230Z     input <- input[((!is.na(input$cens_date_death)) & (year(input$cens_date_death) >= 
2025-08-01T14:25:39.143374995Z         input$qa_num_birth_year)) | (is.na(input$cens_date_death)), 
2025-08-01T14:25:39.143376507Z         ]
2025-08-01T14:25:39.143377958Z     flow[nrow(flow) + 1, ] <- c("Quality assurance: Year of birth is before year of death (if year of death is available)", 
2025-08-01T14:25:39.143379702Z         nrow(input))
2025-08-01T14:25:39.143381118Z     print(flow[nrow(flow), ])
2025-08-01T14:25:39.143382820Z     input <- input[!is.na(input$qa_num_birth_year) & (input$qa_num_birth_year <= 
2025-08-01T14:25:39.143384467Z         lcd_date), ]
2025-08-01T14:25:39.143385933Z     flow[nrow(flow) + 1, ] <- c("Quality assurance: Year of birth is before today (implemented using last data collection date)", 
2025-08-01T14:25:39.143387608Z         nrow(input))
2025-08-01T14:25:39.143388982Z     print(flow[nrow(flow), ])
2025-08-01T14:25:39.143390454Z     input <- input[(!is.na(input$cens_date_death) & (input$cens_date_death <= 
2025-08-01T14:25:39.143392070Z         lcd_date)) | is.na(input$cens_date_death), ]
2025-08-01T14:25:39.143406172Z     flow[nrow(flow) + 1, ] <- c("Quality assurance: Date of death is before today (if year of death is available and implemented using last data collection date)", 
2025-08-01T14:25:39.143408391Z         nrow(input))
2025-08-01T14:25:39.143409817Z     print(flow[nrow(flow), ])
2025-08-01T14:25:39.143411248Z     input <- input[!(input$cov_cat_sex == "male" & input$qa_bin_pregnancy == 
2025-08-01T14:25:39.143412846Z         TRUE), ]
2025-08-01T14:25:39.143416787Z     flow[nrow(flow) + 1, ] <- c("Quality assurance: Men do not have records that contain pregnancy and/or birth codes", 
2025-08-01T14:25:39.143418579Z         nrow(input))
2025-08-01T14:25:39.143419964Z     print(flow[nrow(flow), ])
2025-08-01T14:25:39.143421357Z     input <- input[!(input$cov_cat_sex == "male" & input$qa_bin_hrtcocp == 
2025-08-01T14:25:39.143422920Z         TRUE), ]
2025-08-01T14:25:39.143424262Z     flow[nrow(flow) + 1, ] <- c("Quality assurance: Men do not have records that contain HRT or COCP medication codes", 
2025-08-01T14:25:39.143425870Z         nrow(input))
2025-08-01T14:25:39.143427258Z     print(flow[nrow(flow), ])
2025-08-01T14:25:39.143428697Z     input <- input[!(input$cov_cat_sex == "female" & input$qa_bin_prostate_cancer == 
2025-08-01T14:25:39.143430489Z         TRUE), ]
2025-08-01T14:25:39.143431933Z     flow[nrow(flow) + 1, ] <- c("Quality assurance: Women do not have records that contain prostate cancer codes", 
2025-08-01T14:25:39.143433533Z         nrow(input))
2025-08-01T14:25:39.143434886Z     print(flow[nrow(flow), ])
2025-08-01T14:25:39.143436249Z     return(list(input = input, flow = flow))
2025-08-01T14:25:39.143437637Z }
