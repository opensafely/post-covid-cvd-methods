2025-08-01T14:16:27.779558974Z function (df, controls_per_case, seed = 137, sample_exposed) 
2025-08-01T14:16:27.779597859Z {
2025-08-01T14:16:27.779599439Z     print("Set seed")
2025-08-01T14:16:27.779600676Z     set.seed(seed)
2025-08-01T14:16:27.779601807Z     print("Split cases and controls")
2025-08-01T14:16:27.779603017Z     cases <- df[df$outcome_status == TRUE, ]
2025-08-01T14:16:27.779604319Z     controls <- df[df$outcome_status == FALSE, ]
2025-08-01T14:16:27.779605465Z     print(paste0("Cases: ", nrow(cases)))
2025-08-01T14:16:27.779622022Z     print(summary(cases))
2025-08-01T14:16:27.779623351Z     print(paste0("Controls: ", nrow(controls)))
2025-08-01T14:16:27.779624573Z     print(summary(controls))
2025-08-01T14:16:27.779625698Z     if (sample_exposed == TRUE) {
2025-08-01T14:16:27.779626763Z         if (nrow(cases) * controls_per_case < nrow(controls)) {
2025-08-01T14:16:27.779627970Z             print("Sample controls, including exposed control individuals")
2025-08-01T14:16:27.779629308Z             controls <- controls[sample(seq_len(nrow(controls)), 
2025-08-01T14:16:27.779630481Z                 nrow(cases) * controls_per_case, replace = FALSE), 
2025-08-01T14:16:27.779631585Z                 ]
2025-08-01T14:16:27.779632588Z             controls$cox_weight <- (nrow(df) - nrow(cases))/nrow(controls)
2025-08-01T14:16:27.779633708Z             print(paste0(nrow(controls), " controls sampled with Cox weight of ", 
2025-08-01T14:16:27.779634928Z                 controls$cox_weight[1]))
2025-08-01T14:16:27.779635979Z         }
2025-08-01T14:16:27.779636967Z         else {
2025-08-01T14:16:27.779638004Z             print("Retain all controls")
2025-08-01T14:16:27.779639220Z             controls$cox_weight <- 1
2025-08-01T14:16:27.779640309Z         }
2025-08-01T14:16:27.779641296Z     }
2025-08-01T14:16:27.779642297Z     if (sample_exposed == FALSE) {
2025-08-01T14:16:27.779643337Z         print("Separate exposed controls so they are not sampled")
2025-08-01T14:16:27.779644504Z         controls_exposed <- controls[!is.na(controls$exposure), 
2025-08-01T14:16:27.779645633Z             ]
2025-08-01T14:16:27.779646625Z         controls_exposed$cox_weight <- 1
2025-08-01T14:16:27.779647734Z         print(paste0(nrow(controls_exposed), " exposed controls"))
2025-08-01T14:16:27.779648867Z         print("Exposed controls:")
2025-08-01T14:16:27.779649908Z         print(summary(controls_exposed))
2025-08-01T14:16:27.779650948Z         print("Sample unexposed controls")
2025-08-01T14:16:27.779652014Z         controls_unexposed <- controls[is.na(controls$exposure), 
2025-08-01T14:16:27.779653101Z             ]
2025-08-01T14:16:27.779654053Z         if (nrow(cases) * controls_per_case < nrow(controls_unexposed)) {
2025-08-01T14:16:27.779655282Z             controls_unexposed <- controls_unexposed[sample(seq_len(nrow(controls_unexposed)), 
2025-08-01T14:16:27.779656417Z                 nrow(cases) * controls_per_case, replace = FALSE), 
2025-08-01T14:16:27.779657507Z                 ]
2025-08-01T14:16:27.779658475Z             controls_unexposed$cox_weight <- (nrow(df) - nrow(cases) - 
2025-08-01T14:16:27.779661377Z                 nrow(controls_exposed))/nrow(controls_unexposed)
2025-08-01T14:16:27.779662496Z             print(paste0(nrow(controls_unexposed), " unexposed controls sampled with Cox weight of ", 
2025-08-01T14:16:27.779664132Z                 controls_unexposed$cox_weight[1]))
2025-08-01T14:16:27.779665229Z             print("Unexposed controls:")
2025-08-01T14:16:27.779666283Z             print(summary(controls_unexposed))
2025-08-01T14:16:27.779667323Z             print("Add exposed control individuals back to control dataset")
2025-08-01T14:16:27.779668464Z             controls <- NULL
2025-08-01T14:16:27.779669526Z             controls <- rbind(controls_unexposed, controls_exposed)
2025-08-01T14:16:27.779670644Z             print(paste0("Controls (N=", nrow(controls), "):"))
2025-08-01T14:16:27.779671873Z             print(summary(controls))
2025-08-01T14:16:27.779672904Z         }
2025-08-01T14:16:27.779674007Z         else {
2025-08-01T14:16:27.779675052Z             print("Insufficient controls so retain all controls")
2025-08-01T14:16:27.779676198Z             rm(controls_exposed, controls_unexposed)
2025-08-01T14:16:27.779677224Z             controls$cox_weight <- 1
2025-08-01T14:16:27.779678274Z         }
2025-08-01T14:16:27.779679256Z     }
2025-08-01T14:16:27.779680190Z     print("Specify cox weight for cases")
2025-08-01T14:16:27.779681358Z     cases$cox_weight <- 1
2025-08-01T14:16:27.779682343Z     print("Recombine cases and controls")
2025-08-01T14:16:27.779683364Z     return_df <- rbind(cases, controls)
2025-08-01T14:16:27.779684426Z     return(return_df)
2025-08-01T14:16:27.779685412Z }
2025-08-01T14:16:27.779686359Z 
