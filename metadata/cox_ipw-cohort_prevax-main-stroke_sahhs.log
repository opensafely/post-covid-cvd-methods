2025-08-01T14:16:27.778642629Z function (df, covariate_threshold, strata) 
2025-08-01T14:16:27.778663507Z {
2025-08-01T14:16:27.778667807Z     library(magrittr)
2025-08-01T14:16:27.778670724Z     print("Identify non-numeric covariates to remove")
2025-08-01T14:16:27.778673777Z     covariate_removed <- NULL
2025-08-01T14:16:27.778689376Z     for (i in unique(c(colnames(df)[grepl("cov_", colnames(df))], 
2025-08-01T14:16:27.778692172Z         strata))) {
2025-08-01T14:16:27.778694048Z         if (grepl("cov_bin_", i) || grepl("cov_cat_", i)) {
2025-08-01T14:16:27.778696049Z             print(paste0("Covariate: ", i))
2025-08-01T14:16:27.778697970Z             print("Calculate frequency for each level")
2025-08-01T14:16:27.778700001Z             tmp <- unique(df[df$exposure_status == 1 & df$outcome_status == 
2025-08-01T14:16:27.778702038Z                 1, c("patient_id", i)])
2025-08-01T14:16:27.778703977Z             freq <- data.frame(table(tmp[, i]))
2025-08-01T14:16:27.778705899Z             print(freq)
2025-08-01T14:16:27.778707633Z             if (nrow(freq[freq$Freq <= covariate_threshold & 
2025-08-01T14:16:27.778710221Z                 freq$Var1 != "Missing", ]) > 0) {
2025-08-01T14:16:27.778712243Z                 print("Add covariate to removal list")
2025-08-01T14:16:27.778714105Z                 covariate_removed <- c(covariate_removed, i)
2025-08-01T14:16:27.778715961Z             }
2025-08-01T14:16:27.778717628Z             if (nrow(freq) == 1) {
2025-08-01T14:16:27.778719446Z                 print("Add covariate to removal list")
2025-08-01T14:16:27.778721307Z                 covariate_removed <- c(covariate_removed, i)
2025-08-01T14:16:27.778723111Z             }
2025-08-01T14:16:27.778724782Z         }
2025-08-01T14:16:27.778726464Z     }
2025-08-01T14:16:27.778728137Z     covariate_collapsed <- NULL
2025-08-01T14:16:27.778729947Z     if ("cov_cat_region" %in% covariate_removed) {
2025-08-01T14:16:27.778731746Z         print("Collapsing region as special case")
2025-08-01T14:16:27.778733650Z         df <- df %>% dplyr::mutate(cov_cat_region = dplyr::case_when(cov_cat_region == 
2025-08-01T14:16:27.778735736Z             "North East" ~ "Northern England", cov_cat_region == 
2025-08-01T14:16:27.778737724Z             "North West" ~ "Northern England", cov_cat_region == 
2025-08-01T14:16:27.778739659Z             "Yorkshire and The Humber" ~ "Northern England", 
2025-08-01T14:16:27.778741608Z             cov_cat_region == "London" ~ "Southern England", 
2025-08-01T14:16:27.778743569Z             cov_cat_region == "South East" ~ "Southern England", 
2025-08-01T14:16:27.778745491Z             cov_cat_region == "East Midlands" ~ "Midlands", cov_cat_region == 
2025-08-01T14:16:27.778747463Z                 "West Midlands" ~ "Midlands", cov_cat_region == 
2025-08-01T14:16:27.778749385Z                 "South West" ~ "Southern England", cov_cat_region == 
2025-08-01T14:16:27.778751299Z                 "East" ~ "Southern England"))
2025-08-01T14:16:27.778756787Z         df$cov_cat_region <- factor(df$cov_cat_region)
2025-08-01T14:16:27.778758962Z         df$cov_cat_region <- relevel(df$cov_cat_region, ref = "Southern England")
2025-08-01T14:16:27.778761046Z         covariate_removed <- setdiff(covariate_removed, "cov_cat_region")
2025-08-01T14:16:27.778764017Z         covariate_collapsed <- c(covariate_collapsed, "cov_cat_region")
2025-08-01T14:16:27.778766143Z     }
2025-08-01T14:16:27.778767845Z     if ("cov_cat_deprivation" %in% covariate_removed) {
2025-08-01T14:16:27.778769796Z         print("Collapsing deprivation as special case")
2025-08-01T14:16:27.778771718Z         df <- df %>% dplyr::mutate(cov_cat_deprivation = dplyr::case_when(cov_cat_deprivation == 
2025-08-01T14:16:27.778773745Z             "1-2 (most deprived)" ~ "1-4", cov_cat_deprivation == 
2025-08-01T14:16:27.778775714Z             "3-4" ~ "1-4", cov_cat_deprivation == "5-6" ~ "5-6", 
2025-08-01T14:16:27.778777684Z             cov_cat_deprivation == "7-8" ~ "7-10", cov_cat_deprivation == 
2025-08-01T14:16:27.778779716Z                 "9-10 (least deprived)" ~ "7-10"))
2025-08-01T14:16:27.778781658Z         df$cov_cat_deprivation <- ordered(df$cov_cat_deprivation, 
2025-08-01T14:16:27.778783538Z             levels = c("1-4", "5-6", "7-10"))
2025-08-01T14:16:27.778785500Z         covariate_removed <- setdiff(covariate_removed, "cov_cat_deprivation")
2025-08-01T14:16:27.778787499Z         covariate_collapsed <- c(covariate_collapsed, "cov_cat_deprivation")
2025-08-01T14:16:27.778789420Z     }
2025-08-01T14:16:27.778791065Z     if ("cov_cat_smoking_status" %in% covariate_removed) {
2025-08-01T14:16:27.778793053Z         print("Collapsing smoking status as special case")
2025-08-01T14:16:27.778794931Z         df <- df %>% dplyr::mutate(cov_cat_smoking_status = dplyr::case_when(cov_cat_smoking_status == 
2025-08-01T14:16:27.778796910Z             "Never smoker" ~ "Never smoker", cov_cat_smoking_status == 
2025-08-01T14:16:27.778798840Z             "Ever smoker" ~ "Ever smoker", cov_cat_smoking_status == 
2025-08-01T14:16:27.778800767Z             "Current smoker" ~ "Ever smoker", cov_cat_smoking_status == 
2025-08-01T14:16:27.778802716Z             "Missing" ~ "Missing"))
2025-08-01T14:16:27.778804658Z         df$cov_cat_smoking_status <- ordered(df$cov_cat_smoking_status, 
2025-08-01T14:16:27.778806475Z             levels = c("Never smoker", "Ever smoker", "Missing"))
2025-08-01T14:16:27.778808457Z         covariate_removed <- setdiff(covariate_removed, "cov_cat_smoking_status")
2025-08-01T14:16:27.778810311Z     }
2025-08-01T14:16:27.778811898Z     for (i in c("cov_cat_deprivation", "cov_cat_smoking_status", 
2025-08-01T14:16:27.778813765Z         "cov_cat_region")) {
2025-08-01T14:16:27.778815569Z         if (i %in% colnames(df)) {
2025-08-01T14:16:27.778820150Z             print(paste0("Rechecking covariate: ", i))
2025-08-01T14:16:27.778822298Z             print("Calculate frequency for each level among exposed with outcome")
2025-08-01T14:16:27.778824309Z             tmp <- unique(df[df$exposure_status == 1 & df$outcome_status == 
2025-08-01T14:16:27.778826289Z                 1, c("patient_id", i)])
2025-08-01T14:16:27.778831056Z             freq <- data.frame(table(tmp[, i]))
2025-08-01T14:16:27.778833031Z             print(freq)
2025-08-01T14:16:27.778834775Z             if (nrow(freq[freq$Freq <= covariate_threshold & 
2025-08-01T14:16:27.778837181Z                 freq$Var1 != "Missing", ]) > 0) {
2025-08-01T14:16:27.778839248Z                 print("Add covariate to removal list")
2025-08-01T14:16:27.778841202Z                 covariate_removed <- c(covariate_removed, i)
2025-08-01T14:16:27.778843133Z                 covariate_collapsed <- setdiff(covariate_collapsed, 
2025-08-01T14:16:27.778844980Z                   i)
2025-08-01T14:16:27.778846692Z             }
2025-08-01T14:16:27.778848408Z             if (nrow(freq) == 1) {
2025-08-01T14:16:27.778850090Z                 print("Add covariate to removal list")
2025-08-01T14:16:27.778851921Z                 covariate_removed <- c(covariate_removed, i)
2025-08-01T14:16:27.778853747Z                 covariate_collapsed <- setdiff(covariate_collapsed, 
2025-08-01T14:16:27.778855715Z                   i)
2025-08-01T14:16:27.778857533Z             }
2025-08-01T14:16:27.778859192Z         }
2025-08-01T14:16:27.778861040Z     }
2025-08-01T14:16:27.778862864Z     print("Check strata variables meet covariate threshold")
2025-08-01T14:16:27.778864800Z     strata_warning <- ""
2025-08-01T14:16:27.778866760Z     if (length(intersect(covariate_removed, strata)) > 0) {
2025-08-01T14:16:27.778868718Z         strata_warning <- paste0(intersect(covariate_removed, 
2025-08-01T14:16:27.778870552Z             strata), collapse = ";")
2025-08-01T14:16:27.778872315Z         for (i in intersect(covariate_removed, strata)) {
2025-08-01T14:16:27.778874086Z             tmp <- unique(df[df$exposure_status == 1 & df$outcome_status == 
2025-08-01T14:16:27.778875929Z                 1, c("patient_id", i)])
2025-08-01T14:16:27.778877641Z             freq <- data.frame(table(tmp[, i]))
2025-08-01T14:16:27.778879452Z             print(paste0("Warning: strata variable '", i, "' does not meet covariate threshold"))
2025-08-01T14:16:27.778881518Z             print(freq)
2025-08-01T14:16:27.778883361Z         }
2025-08-01T14:16:27.778885086Z     }
2025-08-01T14:16:27.778886754Z     print("Remove covariates")
2025-08-01T14:16:27.778890901Z     df <- df[, !(colnames(df) %in% setdiff(covariate_removed, 
2025-08-01T14:16:27.778893092Z         strata))]
2025-08-01T14:16:27.778895132Z     output <- list(df = df, covariate_removed = setdiff(covariate_removed, 
2025-08-01T14:16:27.778897273Z         strata), covariate_collapsed = covariate_collapsed, strata_warning = strata_warning)
2025-08-01T14:16:27.778899663Z     return(output)
2025-08-01T14:16:27.778901594Z }
2025-08-01T14:16:27.778903981Z 
2025-08-01T14:16:27.778905688Z [[1]]$visible
2025-08-01T14:16:27.778907339Z [1] FALSE
