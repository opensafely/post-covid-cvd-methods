2025-08-01T14:16:27.779844994Z function (df, cut_points, episode_labels) 
2025-08-01T14:16:27.779856318Z {
2025-08-01T14:16:27.779858871Z     print("Calculate where follow-up occurs in study period")
2025-08-01T14:16:27.779861413Z     df$days_to_start <- as.numeric(df$fup_start - df$study_start)
2025-08-01T14:16:27.779863815Z     df$days_to_end <- as.numeric(df$fup_stop - df$study_start) + 
2025-08-01T14:16:27.779866279Z         1
2025-08-01T14:16:27.779868392Z     print("Set survival data for the exposed")
2025-08-01T14:16:27.779870607Z     print("Filter data to exposed")
2025-08-01T14:16:27.779872847Z     exposed <- df[!is.na(df$exposure), ]
2025-08-01T14:16:27.779883275Z     print("Calculate days to exposure")
2025-08-01T14:16:27.779886151Z     exposed$days_to_exp <- as.numeric(exposed$exposure - exposed$study_start)
2025-08-01T14:16:27.779888570Z     print("Put into survival format (dataset d1)")
2025-08-01T14:16:27.779890882Z     d1 <- exposed[, !(colnames(exposed) %in% c("days_to_start", 
2025-08-01T14:16:27.779893278Z         "days_to_exp", "days_to_end", "outcome_status"))]
2025-08-01T14:16:27.779895696Z     print(summary(d1))
2025-08-01T14:16:27.779897817Z     print("Put into survival format (dataset d2)")
2025-08-01T14:16:27.779900266Z     d2 <- exposed[, c("patient_id", "days_to_start", "days_to_exp", 
2025-08-01T14:16:27.779902734Z         "days_to_end", "outcome_status")]
2025-08-01T14:16:27.779905054Z     print(summary(d2))
2025-08-01T14:16:27.779907230Z     print("Put into survival format (tmerge)")
2025-08-01T14:16:27.779909487Z     exposed <- survival::tmerge(data1 = d1, data2 = d2, id = patient_id, 
2025-08-01T14:16:27.779911836Z         outcome_status = event(days_to_end, outcome_status), 
2025-08-01T14:16:27.779914119Z         tstart = days_to_start, tstop = days_to_end, exposure_status = tdc(days_to_exp))
2025-08-01T14:16:27.779916497Z     print(summary(exposed))
2025-08-01T14:16:27.779918771Z     print("Split post-exposure time for the exposed")
2025-08-01T14:16:27.779920982Z     print("Filter to post-exposure data")
2025-08-01T14:16:27.779923232Z     exposed_post <- exposed[exposed$exposure_status == 1, ]
2025-08-01T14:16:27.779925589Z     print("Format tstart and tstop")
2025-08-01T14:16:27.779927745Z     exposed_post <- dplyr::rename(exposed_post, t0 = tstart, 
2025-08-01T14:16:27.779930054Z         t = tstop)
2025-08-01T14:16:27.779932177Z     exposed_post$tstart <- 0
2025-08-01T14:16:27.779934387Z     exposed_post$tstop <- exposed_post$t - exposed_post$t0
2025-08-01T14:16:27.779936666Z     print("Implement post-exposure cut points")
2025-08-01T14:16:27.779938911Z     print(summary(exposed_post))
2025-08-01T14:16:27.779941150Z     exposed_post <- survival::survSplit(Surv(tstop, outcome_status) ~ 
2025-08-01T14:16:27.779943419Z         ., exposed_post, cut = cut_points, episode = "episode")
2025-08-01T14:16:27.779945701Z     print(summary(exposed_post))
2025-08-01T14:16:27.779947821Z     print("Account for pre-exposure time")
2025-08-01T14:16:27.779950107Z     exposed_post$tstart <- exposed_post$tstart + exposed_post$t0
2025-08-01T14:16:27.779952406Z     exposed_post$tstop <- exposed_post$tstop + exposed_post$t0
2025-08-01T14:16:27.779954702Z     exposed_post[, c("t0", "t")] <- NULL
2025-08-01T14:16:27.779957223Z     print(summary(exposed_post))
2025-08-01T14:16:27.779962750Z     print("Combine pre- and post-exposure time for the exposed")
2025-08-01T14:16:27.779965592Z     print("Filter to pre-exposure data")
2025-08-01T14:16:27.779967889Z     exposed_pre <- exposed[exposed$exposure_status == 0, ]
2025-08-01T14:16:27.779970346Z     if (nrow(exposed_pre) > 0) {
2025-08-01T14:16:27.779974792Z         print("Set pre-exposure to be episode 0")
2025-08-01T14:16:27.779977177Z         exposed_pre$episode <- 0
2025-08-01T14:16:27.779979388Z         print(summary(exposed_pre))
2025-08-01T14:16:27.779981497Z         print("Bind pre- and post-exposure time")
2025-08-01T14:16:27.779983710Z         exposed <- plyr::rbind.fill(exposed_pre, exposed_post)
2025-08-01T14:16:27.779986015Z     }
2025-08-01T14:16:27.779988081Z     else {
2025-08-01T14:16:27.779990250Z         print("No pre-exposure time so exposed = post-exposure time only")
2025-08-01T14:16:27.779992585Z         exposed <- exposed_post
2025-08-01T14:16:27.779994816Z     }
2025-08-01T14:16:27.779996851Z     print(summary(exposed))
2025-08-01T14:16:27.779998980Z     print("Set survival data for the unexposed")
2025-08-01T14:16:27.780001331Z     print("Filter data to unexposed")
2025-08-01T14:16:27.780003572Z     unexposed <- df[is.na(df$exposure), ]
2025-08-01T14:16:27.780005859Z     print("Rename variables to survival variable names")
2025-08-01T14:16:27.780008167Z     unexposed <- dplyr::rename(unexposed, tstart = "days_to_start", 
2025-08-01T14:16:27.780010604Z         tstop = "days_to_end")
2025-08-01T14:16:27.780012855Z     unexposed$exposure_status <- c(0)
2025-08-01T14:16:27.780015121Z     unexposed$episode <- c(0)
2025-08-01T14:16:27.780017361Z     unexposed$outcome_status <- as.numeric(unexposed$outcome_status)
2025-08-01T14:16:27.780019669Z     print(summary(unexposed))
2025-08-01T14:16:27.780021853Z     print("Combine exposed and unexposed individuals")
2025-08-01T14:16:27.780024174Z     exposed <- exposed[, intersect(colnames(unexposed), colnames(exposed))]
2025-08-01T14:16:27.780026507Z     unexposed <- unexposed[, intersect(colnames(unexposed), colnames(exposed))]
2025-08-01T14:16:27.780028887Z     df <- rbind(exposed, unexposed)
2025-08-01T14:16:27.780031073Z     print(summary(df))
2025-08-01T14:16:27.780033136Z     print("Add indicators for episode")
2025-08-01T14:16:27.780035377Z     for (i in 1:max(episode_labels$episode)) {
2025-08-01T14:16:27.780037568Z         preserve_cols <- colnames(df)
2025-08-01T14:16:27.780039700Z         df$tmp <- as.numeric(df$episode == i)
2025-08-01T14:16:27.780042033Z         colnames(df) <- c(preserve_cols, episode_labels[episode_labels$episode == 
2025-08-01T14:16:27.780047061Z             i, ]$time_period)
2025-08-01T14:16:27.780049678Z     }
2025-08-01T14:16:27.780051853Z     print(summary(df))
2025-08-01T14:16:27.780053993Z     return(df)
2025-08-01T14:16:27.780056098Z }
2025-08-01T14:16:27.780058193Z 
