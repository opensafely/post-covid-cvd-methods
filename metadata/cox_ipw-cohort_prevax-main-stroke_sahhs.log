2025-08-01T14:16:27.778922050Z function (df, time_periods, covariates, strata, age_spline, covariate_removed, 
2025-08-01T14:16:27.778924748Z     covariate_collapsed, ipw) 
2025-08-01T14:16:27.778926501Z {
2025-08-01T14:16:27.778928104Z     print("Define model formula")
2025-08-01T14:16:27.778929846Z     surv_formula <- paste0("Surv(tstart, tstop, outcome_status) ~ ", 
2025-08-01T14:16:27.778931680Z         paste(time_periods, collapse = " + "), ifelse("cov_cat_sex" %in% 
2025-08-01T14:16:27.778933509Z             colnames(df), " + cov_cat_sex", ""), ifelse(is.null(strata), 
2025-08-01T14:16:27.778935335Z             "", paste(" +", paste0("rms::strat(", strata, ")"), 
2025-08-01T14:16:27.778937298Z                 collapse = " + ")), ifelse(isTRUE(ipw), " + cluster(patient_id)", 
2025-08-01T14:16:27.778939149Z             ""))
2025-08-01T14:16:27.778940783Z     if ("cov_num_age" %in% colnames(df)) {
2025-08-01T14:16:27.778942460Z         print("Add age covariate")
2025-08-01T14:16:27.778944146Z         if (age_spline == TRUE) {
2025-08-01T14:16:27.778945733Z             print("Specify knot placement for age spline")
2025-08-01T14:16:27.778947456Z             knot_placement <- as.numeric(quantile(df$cov_num_age, 
2025-08-01T14:16:27.778949210Z                 probs = c(0.1, 0.5, 0.9)))
2025-08-01T14:16:27.778950837Z             print(paste0("Knots will be placed at: ", paste0(knot_placement, 
2025-08-01T14:16:27.778952572Z                 collapse = ", ")))
2025-08-01T14:16:27.778954291Z             surv_formula <- paste0(surv_formula, " + rms::rcs(cov_num_age, parms=knot_placement)")
2025-08-01T14:16:27.778956202Z         }
2025-08-01T14:16:27.778957781Z         else {
2025-08-01T14:16:27.778959398Z             surv_formula <- paste0(surv_formula, " + cov_num_age + cov_num_age_sq")
2025-08-01T14:16:27.778961225Z         }
2025-08-01T14:16:27.778964955Z     }
2025-08-01T14:16:27.778966795Z     print(surv_formula)
2025-08-01T14:16:27.778985177Z     print("Fit Cox model")
2025-08-01T14:16:27.778987098Z     dd <<- rms::datadist(df)
2025-08-01T14:16:27.778988932Z     withr::local_options(list(datadist = "dd", contrasts = c("contr.treatment", 
2025-08-01T14:16:27.778990809Z         "contr.treatment")))
2025-08-01T14:16:27.778993958Z     if (ipw == TRUE) {
2025-08-01T14:16:27.778995615Z         N_obs_in <- nrow(df)
2025-08-01T14:16:27.778997331Z         fit_cox_model <- rms::cph(formula = as.formula(surv_formula), 
2025-08-01T14:16:27.778999081Z             data = df, weight = df$cox_weight, method = "breslow", 
2025-08-01T14:16:27.779000847Z             surv = TRUE, x = TRUE, y = TRUE)
2025-08-01T14:16:27.779002545Z         N_obs_out <- sum(fit_cox_model$n)
2025-08-01T14:16:27.779004312Z     }
2025-08-01T14:16:27.779005936Z     else {
2025-08-01T14:16:27.779007561Z         N_obs_in <- nrow(df)
2025-08-01T14:16:27.779009303Z         fit_cox_model <- rms::cph(formula = as.formula(surv_formula), 
2025-08-01T14:16:27.779011115Z             data = df, method = "breslow", surv = TRUE, x = TRUE, 
2025-08-01T14:16:27.779012903Z             y = TRUE)
2025-08-01T14:16:27.779014572Z         N_obs_out <- sum(fit_cox_model$n)
2025-08-01T14:16:27.779016304Z     }
2025-08-01T14:16:27.779017878Z     print(fit_cox_model)
2025-08-01T14:16:27.779019554Z     print("Format results")
2025-08-01T14:16:27.779021278Z     results <- data.frame(term = names(fit_cox_model$coefficients), 
2025-08-01T14:16:27.779024037Z         lnhr = fit_cox_model$coefficients, se_lnhr = sqrt(diag(vcov(fit_cox_model))), 
2025-08-01T14:16:27.779026303Z         model = "mdl_age_sex", surv_formula = surv_formula, covariate_removed = "", 
2025-08-01T14:16:27.779028378Z         covariate_collapsed = "", obs_warning = ifelse(N_obs_in == 
2025-08-01T14:16:27.779030273Z             N_obs_out, "", paste0(N_obs_in, " observations provided. ", 
2025-08-01T14:16:27.779032250Z             N_obs_out, " observations used.")), stringsAsFactors = FALSE)
2025-08-01T14:16:27.779034201Z     row.names(results) <- NULL
2025-08-01T14:16:27.779036052Z     covariates <- setdiff(covariates, covariate_removed)
2025-08-01T14:16:27.779037991Z     if (!is.null(covariates) && length(covariates) > 0) {
2025-08-01T14:16:27.779040150Z         print("Add covariates to model formula")
2025-08-01T14:16:27.779042056Z         surv_formula_adj <- paste0(surv_formula, " + ", paste(covariates, 
2025-08-01T14:16:27.779044061Z             collapse = " + "))
2025-08-01T14:16:27.779045916Z         print(surv_formula_adj)
2025-08-01T14:16:27.779050263Z         print("Fit Cox model with covariates")
2025-08-01T14:16:27.779052484Z         dd_adj <<- rms::datadist(df)
2025-08-01T14:16:27.779054531Z         withr::local_options(list(datadist = "dd_adj", contrasts = c("contr.treatment", 
2025-08-01T14:16:27.779056706Z             "contr.treatment")))
2025-08-01T14:16:27.779058650Z         if (ipw == TRUE) {
2025-08-01T14:16:27.779060562Z             N_obs_in <- nrow(df)
2025-08-01T14:16:27.779062495Z             fit_cox_model_adj <- rms::cph(formula = as.formula(surv_formula_adj), 
2025-08-01T14:16:27.779064426Z                 data = df, weight = df$cox_weight, method = "breslow", 
2025-08-01T14:16:27.779066354Z                 surv = TRUE, x = TRUE, y = TRUE)
2025-08-01T14:16:27.779068187Z             N_obs_out <- sum(fit_cox_model$n)
2025-08-01T14:16:27.779070070Z         }
2025-08-01T14:16:27.779071828Z         else {
2025-08-01T14:16:27.779073585Z             N_obs_in <- nrow(df)
2025-08-01T14:16:27.779075580Z             fit_cox_model_adj <- rms::cph(formula = as.formula(surv_formula_adj), 
2025-08-01T14:16:27.779077498Z                 data = df, method = "breslow", surv = TRUE, x = TRUE, 
2025-08-01T14:16:27.779079518Z                 y = TRUE)
2025-08-01T14:16:27.779081330Z             N_obs_out <- sum(fit_cox_model$n)
2025-08-01T14:16:27.779083181Z         }
2025-08-01T14:16:27.779084972Z         print(fit_cox_model_adj)
2025-08-01T14:16:27.779086853Z         print("Format results")
2025-08-01T14:16:27.779088729Z         results_adj <- data.frame(term = names(fit_cox_model_adj$coefficients), 
2025-08-01T14:16:27.779090920Z             lnhr = fit_cox_model_adj$coefficients, se_lnhr = sqrt(diag(vcov(fit_cox_model_adj))), 
2025-08-01T14:16:27.779092946Z             model = "mdl_max_adj", surv_formula = surv_formula_adj, 
2025-08-01T14:16:27.779094942Z             covariate_removed = paste0(covariate_removed, collapse = ";"), 
2025-08-01T14:16:27.779096945Z             covariate_collapsed = paste0(covariate_collapsed, 
2025-08-01T14:16:27.779098876Z                 collapse = ";"), obs_warning = ifelse(N_obs_in == 
2025-08-01T14:16:27.779101448Z                 N_obs_out, "", paste0(N_obs_in, " observations provided. ", 
2025-08-01T14:16:27.779103656Z                 N_obs_out, " observations used.")), stringsAsFactors = FALSE)
2025-08-01T14:16:27.779105733Z         row.names(results_adj) <- NULL
2025-08-01T14:16:27.779107604Z         print("Bind to other results")
2025-08-01T14:16:27.779109685Z         results <- rbind(results, results_adj)
2025-08-01T14:16:27.779111546Z     }
2025-08-01T14:16:27.779113383Z     print("Return results")
2025-08-01T14:16:27.779117852Z     return(results)
2025-08-01T14:16:27.779119952Z     print(summary(results))
2025-08-01T14:16:27.779121959Z }
