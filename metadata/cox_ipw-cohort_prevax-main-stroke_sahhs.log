2025-08-01T14:16:27.779135810Z function (df, cut_points, episode_labels, ipw) 
2025-08-01T14:16:27.779137612Z {
2025-08-01T14:16:27.779139326Z     library(magrittr)
2025-08-01T14:16:27.779141064Z     print("Calculate number of events per episode")
2025-08-01T14:16:27.779143064Z     events <- df[df$outcome_status == 1, c("patient_id", "episode")]
2025-08-01T14:16:27.779145139Z     events <- aggregate(episode ~ patient_id, data = events, 
2025-08-01T14:16:27.779147097Z         FUN = max)
2025-08-01T14:16:27.779148918Z     events <- data.frame(table(events$episode), stringsAsFactors = FALSE)
2025-08-01T14:16:27.779150868Z     events <- dplyr::rename(events, episode = "Var1", N_events = "Freq")
2025-08-01T14:16:27.779152980Z     print(events)
2025-08-01T14:16:27.779154823Z     print("Add number of events to episode info table")
2025-08-01T14:16:27.779156780Z     episode_info <- merge(episode_labels, events, by = "episode", 
2025-08-01T14:16:27.779158781Z         all.x = TRUE)
2025-08-01T14:16:27.779160592Z     episode_info$N_events <- ifelse(is.na(episode_info$N_events), 
2025-08-01T14:16:27.779162575Z         0, episode_info$N_events)
2025-08-01T14:16:27.779164341Z     print(episode_info)
2025-08-01T14:16:27.779166151Z     print("Calculate person-time in each episode")
2025-08-01T14:16:27.779168164Z     if (ipw == TRUE) {
2025-08-01T14:16:27.779169990Z         tmp <- df[, c("episode", "tstart", "tstop", "cox_weight")]
2025-08-01T14:16:27.779172262Z         tmp$person_time_total <- (tmp$tstop - tmp$tstart) * tmp$cox_weight
2025-08-01T14:16:27.779193127Z         tmp[, c("tstart", "tstop", "cox_weight")] <- NULL
2025-08-01T14:16:27.779202484Z     }
2025-08-01T14:16:27.779204636Z     if (ipw == FALSE) {
2025-08-01T14:16:27.779206658Z         tmp <- df[, c("episode", "tstart", "tstop")]
2025-08-01T14:16:27.779208786Z         tmp$person_time_total <- (tmp$tstop - tmp$tstart)
2025-08-01T14:16:27.779210859Z         tmp[, c("tstart", "tstop")] <- NULL
2025-08-01T14:16:27.779213193Z     }
2025-08-01T14:16:27.779214928Z     tmp <- aggregate(person_time_total ~ episode, data = tmp, 
2025-08-01T14:16:27.779221318Z         FUN = sum)
2025-08-01T14:16:27.779223448Z     episode_info <- merge(episode_info, tmp, by = "episode", 
2025-08-01T14:16:27.779225507Z         all.x = TRUE)
2025-08-01T14:16:27.779227334Z     print(episode_info)
2025-08-01T14:16:27.779229101Z     print("Calculate median person-time")
2025-08-01T14:16:27.779230937Z     tmp <- df[df$outcome_status == 1, c("episode", "tstart", 
2025-08-01T14:16:27.779233108Z         "tstop")]
2025-08-01T14:16:27.779234955Z     tmp$outcome_time <- tmp$tstop - tmp$tstart
2025-08-01T14:16:27.779236924Z     tmp <- tmp %>% dplyr::group_by(episode) %>% dplyr::mutate(outcome_time_median = median(outcome_time)) %>% 
2025-08-01T14:16:27.779239183Z         dplyr::ungroup(episode)
2025-08-01T14:16:27.779242453Z     tmp <- unique(tmp[, c("episode", "outcome_time_median")])
2025-08-01T14:16:27.779244654Z     episode_info <- merge(episode_info, tmp, by = "episode", 
2025-08-01T14:16:27.779246758Z         all.x = TRUE)
2025-08-01T14:16:27.779248568Z     print(episode_info)
2025-08-01T14:16:27.779250417Z     print("Add time from previous episodes to median person-time")
2025-08-01T14:16:27.779252426Z     episode_info$add <- as.numeric(gsub("days", "", gsub("_.*", 
2025-08-01T14:16:27.779254565Z         "", episode_info$time_period)))
2025-08-01T14:16:27.779256507Z     episode_info$add <- ifelse(is.na(episode_info$add), 0, episode_info$add)
2025-08-01T14:16:27.779258464Z     episode_info$outcome_time_median <- episode_info$outcome_time_median + 
2025-08-01T14:16:27.779260537Z         episode_info$add
2025-08-01T14:16:27.779262425Z     episode_info$add <- NULL
2025-08-01T14:16:27.779264251Z     print(episode_info)
2025-08-01T14:16:27.779266058Z     return(episode_info)
2025-08-01T14:16:27.779267891Z }
