2025-08-01T14:16:16.232502627Z function (df, cut_points, episode_labels, ipw) 
2025-08-01T14:16:16.232514884Z {
2025-08-01T14:16:16.232517128Z     library(magrittr)
2025-08-01T14:16:16.232518863Z     print("Calculate number of events per episode")
2025-08-01T14:16:16.232520626Z     events <- df[df$outcome_status == 1, c("patient_id", "episode")]
2025-08-01T14:16:16.232522643Z     events <- aggregate(episode ~ patient_id, data = events, 
2025-08-01T14:16:16.232524325Z         FUN = max)
2025-08-01T14:16:16.232525870Z     events <- data.frame(table(events$episode), stringsAsFactors = FALSE)
2025-08-01T14:16:16.232527604Z     events <- dplyr::rename(events, episode = "Var1", N_events = "Freq")
2025-08-01T14:16:16.232529396Z     print(events)
2025-08-01T14:16:16.232530920Z     print("Add number of events to episode info table")
2025-08-01T14:16:16.232532538Z     episode_info <- merge(episode_labels, events, by = "episode", 
2025-08-01T14:16:16.232534211Z         all.x = TRUE)
2025-08-01T14:16:16.232535669Z     episode_info$N_events <- ifelse(is.na(episode_info$N_events), 
2025-08-01T14:16:16.232537273Z         0, episode_info$N_events)
2025-08-01T14:16:16.232538736Z     print(episode_info)
2025-08-01T14:16:16.232540135Z     print("Calculate person-time in each episode")
2025-08-01T14:16:16.232541637Z     if (ipw == TRUE) {
2025-08-01T14:16:16.232543054Z         tmp <- df[, c("episode", "tstart", "tstop", "cox_weight")]
2025-08-01T14:16:16.232544842Z         tmp$person_time_total <- (tmp$tstop - tmp$tstart) * tmp$cox_weight
2025-08-01T14:16:16.232546437Z         tmp[, c("tstart", "tstop", "cox_weight")] <- NULL
2025-08-01T14:16:16.232548175Z     }
2025-08-01T14:16:16.232549615Z     if (ipw == FALSE) {
2025-08-01T14:16:16.232551055Z         tmp <- df[, c("episode", "tstart", "tstop")]
2025-08-01T14:16:16.232552668Z         tmp$person_time_total <- (tmp$tstop - tmp$tstart)
2025-08-01T14:16:16.232554230Z         tmp[, c("tstart", "tstop")] <- NULL
2025-08-01T14:16:16.232555882Z     }
2025-08-01T14:16:16.232557293Z     tmp <- aggregate(person_time_total ~ episode, data = tmp, 
2025-08-01T14:16:16.232558858Z         FUN = sum)
2025-08-01T14:16:16.232568601Z     episode_info <- merge(episode_info, tmp, by = "episode", 
2025-08-01T14:16:16.232570825Z         all.x = TRUE)
2025-08-01T14:16:16.232572372Z     print(episode_info)
2025-08-01T14:16:16.232573859Z     print("Calculate median person-time")
2025-08-01T14:16:16.232575398Z     tmp <- df[df$outcome_status == 1, c("episode", "tstart", 
2025-08-01T14:16:16.232577069Z         "tstop")]
2025-08-01T14:16:16.232578563Z     tmp$outcome_time <- tmp$tstop - tmp$tstart
2025-08-01T14:16:16.232580161Z     tmp <- tmp %>% dplyr::group_by(episode) %>% dplyr::mutate(outcome_time_median = median(outcome_time)) %>% 
2025-08-01T14:16:16.232582008Z         dplyr::ungroup(episode)
2025-08-01T14:16:16.232583487Z     tmp <- unique(tmp[, c("episode", "outcome_time_median")])
2025-08-01T14:16:16.232585170Z     episode_info <- merge(episode_info, tmp, by = "episode", 
2025-08-01T14:16:16.232586745Z         all.x = TRUE)
2025-08-01T14:16:16.232588181Z     print(episode_info)
2025-08-01T14:16:16.232589594Z     print("Add time from previous episodes to median person-time")
2025-08-01T14:16:16.232591172Z     episode_info$add <- as.numeric(gsub("days", "", gsub("_.*", 
2025-08-01T14:16:16.232592886Z         "", episode_info$time_period)))
2025-08-01T14:16:16.232595200Z     episode_info$add <- ifelse(is.na(episode_info$add), 0, episode_info$add)
2025-08-01T14:16:16.232596913Z     episode_info$outcome_time_median <- episode_info$outcome_time_median + 
2025-08-01T14:16:16.232598591Z         episode_info$add
2025-08-01T14:16:16.232606956Z     episode_info$add <- NULL
2025-08-01T14:16:16.232608730Z     print(episode_info)
2025-08-01T14:16:16.232610182Z     return(episode_info)
2025-08-01T14:16:16.232611664Z }
