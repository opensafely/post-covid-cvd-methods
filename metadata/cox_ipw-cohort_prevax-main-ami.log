2025-08-01T14:16:16.232080771Z function (df, covariate_threshold, strata) 
2025-08-01T14:16:16.232087435Z {
2025-08-01T14:16:16.232089462Z     library(magrittr)
2025-08-01T14:16:16.232091455Z     print("Identify non-numeric covariates to remove")
2025-08-01T14:16:16.232093186Z     covariate_removed <- NULL
2025-08-01T14:16:16.232103623Z     for (i in unique(c(colnames(df)[grepl("cov_", colnames(df))], 
2025-08-01T14:16:16.232105740Z         strata))) {
2025-08-01T14:16:16.232107273Z         if (grepl("cov_bin_", i) || grepl("cov_cat_", i)) {
2025-08-01T14:16:16.232108986Z             print(paste0("Covariate: ", i))
2025-08-01T14:16:16.232110510Z             print("Calculate frequency for each level")
2025-08-01T14:16:16.232112091Z             tmp <- unique(df[df$exposure_status == 1 & df$outcome_status == 
2025-08-01T14:16:16.232113724Z                 1, c("patient_id", i)])
2025-08-01T14:16:16.232115237Z             freq <- data.frame(table(tmp[, i]))
2025-08-01T14:16:16.232116721Z             print(freq)
2025-08-01T14:16:16.232118120Z             if (nrow(freq[freq$Freq <= covariate_threshold & 
2025-08-01T14:16:16.232119676Z                 freq$Var1 != "Missing", ]) > 0) {
2025-08-01T14:16:16.232121223Z                 print("Add covariate to removal list")
2025-08-01T14:16:16.232122696Z                 covariate_removed <- c(covariate_removed, i)
2025-08-01T14:16:16.232124232Z             }
2025-08-01T14:16:16.232125570Z             if (nrow(freq) == 1) {
2025-08-01T14:16:16.232126940Z                 print("Add covariate to removal list")
2025-08-01T14:16:16.232128365Z                 covariate_removed <- c(covariate_removed, i)
2025-08-01T14:16:16.232129825Z             }
2025-08-01T14:16:16.232131169Z         }
2025-08-01T14:16:16.232132541Z     }
2025-08-01T14:16:16.232133920Z     covariate_collapsed <- NULL
2025-08-01T14:16:16.232135361Z     if ("cov_cat_region" %in% covariate_removed) {
2025-08-01T14:16:16.232136838Z         print("Collapsing region as special case")
2025-08-01T14:16:16.232138298Z         df <- df %>% dplyr::mutate(cov_cat_region = dplyr::case_when(cov_cat_region == 
2025-08-01T14:16:16.232139857Z             "North East" ~ "Northern England", cov_cat_region == 
2025-08-01T14:16:16.232141391Z             "North West" ~ "Northern England", cov_cat_region == 
2025-08-01T14:16:16.232142845Z             "Yorkshire and The Humber" ~ "Northern England", 
2025-08-01T14:16:16.232144385Z             cov_cat_region == "London" ~ "Southern England", 
2025-08-01T14:16:16.232145926Z             cov_cat_region == "South East" ~ "Southern England", 
2025-08-01T14:16:16.232147528Z             cov_cat_region == "East Midlands" ~ "Midlands", cov_cat_region == 
2025-08-01T14:16:16.232149206Z                 "West Midlands" ~ "Midlands", cov_cat_region == 
2025-08-01T14:16:16.232150838Z                 "South West" ~ "Southern England", cov_cat_region == 
2025-08-01T14:16:16.232152446Z                 "East" ~ "Southern England"))
2025-08-01T14:16:16.232154030Z         df$cov_cat_region <- factor(df$cov_cat_region)
2025-08-01T14:16:16.232157837Z         df$cov_cat_region <- relevel(df$cov_cat_region, ref = "Southern England")
2025-08-01T14:16:16.232159861Z         covariate_removed <- setdiff(covariate_removed, "cov_cat_region")
2025-08-01T14:16:16.232162067Z         covariate_collapsed <- c(covariate_collapsed, "cov_cat_region")
2025-08-01T14:16:16.232163866Z     }
2025-08-01T14:16:16.232165359Z     if ("cov_cat_deprivation" %in% covariate_removed) {
2025-08-01T14:16:16.232167014Z         print("Collapsing deprivation as special case")
2025-08-01T14:16:16.232168674Z         df <- df %>% dplyr::mutate(cov_cat_deprivation = dplyr::case_when(cov_cat_deprivation == 
2025-08-01T14:16:16.232170374Z             "1-2 (most deprived)" ~ "1-4", cov_cat_deprivation == 
2025-08-01T14:16:16.232172067Z             "3-4" ~ "1-4", cov_cat_deprivation == "5-6" ~ "5-6", 
2025-08-01T14:16:16.232173805Z             cov_cat_deprivation == "7-8" ~ "7-10", cov_cat_deprivation == 
2025-08-01T14:16:16.232193083Z                 "9-10 (least deprived)" ~ "7-10"))
2025-08-01T14:16:16.232195120Z         df$cov_cat_deprivation <- ordered(df$cov_cat_deprivation, 
2025-08-01T14:16:16.232196870Z             levels = c("1-4", "5-6", "7-10"))
2025-08-01T14:16:16.232198567Z         covariate_removed <- setdiff(covariate_removed, "cov_cat_deprivation")
2025-08-01T14:16:16.232200200Z         covariate_collapsed <- c(covariate_collapsed, "cov_cat_deprivation")
2025-08-01T14:16:16.232201840Z     }
2025-08-01T14:16:16.232203251Z     if ("cov_cat_smoking_status" %in% covariate_removed) {
2025-08-01T14:16:16.232204847Z         print("Collapsing smoking status as special case")
2025-08-01T14:16:16.232206440Z         df <- df %>% dplyr::mutate(cov_cat_smoking_status = dplyr::case_when(cov_cat_smoking_status == 
2025-08-01T14:16:16.232208123Z             "Never smoker" ~ "Never smoker", cov_cat_smoking_status == 
2025-08-01T14:16:16.232209775Z             "Ever smoker" ~ "Ever smoker", cov_cat_smoking_status == 
2025-08-01T14:16:16.232211563Z             "Current smoker" ~ "Ever smoker", cov_cat_smoking_status == 
2025-08-01T14:16:16.232213236Z             "Missing" ~ "Missing"))
2025-08-01T14:16:16.232214965Z         df$cov_cat_smoking_status <- ordered(df$cov_cat_smoking_status, 
2025-08-01T14:16:16.232216636Z             levels = c("Never smoker", "Ever smoker", "Missing"))
2025-08-01T14:16:16.232218452Z         covariate_removed <- setdiff(covariate_removed, "cov_cat_smoking_status")
2025-08-01T14:16:16.232220097Z     }
2025-08-01T14:16:16.232221548Z     for (i in c("cov_cat_deprivation", "cov_cat_smoking_status", 
2025-08-01T14:16:16.232223262Z         "cov_cat_region")) {
2025-08-01T14:16:16.232224785Z         if (i %in% colnames(df)) {
2025-08-01T14:16:16.232230097Z             print(paste0("Rechecking covariate: ", i))
2025-08-01T14:16:16.232232841Z             print("Calculate frequency for each level among exposed with outcome")
2025-08-01T14:16:16.232235127Z             tmp <- unique(df[df$exposure_status == 1 & df$outcome_status == 
2025-08-01T14:16:16.232236910Z                 1, c("patient_id", i)])
2025-08-01T14:16:16.232238817Z             freq <- data.frame(table(tmp[, i]))
2025-08-01T14:16:16.232240338Z             print(freq)
2025-08-01T14:16:16.232242006Z             if (nrow(freq[freq$Freq <= covariate_threshold & 
2025-08-01T14:16:16.232244643Z                 freq$Var1 != "Missing", ]) > 0) {
2025-08-01T14:16:16.232246674Z                 print("Add covariate to removal list")
2025-08-01T14:16:16.232248247Z                 covariate_removed <- c(covariate_removed, i)
2025-08-01T14:16:16.232249845Z                 covariate_collapsed <- setdiff(covariate_collapsed, 
2025-08-01T14:16:16.232251406Z                   i)
2025-08-01T14:16:16.232252917Z             }
2025-08-01T14:16:16.232254349Z             if (nrow(freq) == 1) {
2025-08-01T14:16:16.232255870Z                 print("Add covariate to removal list")
2025-08-01T14:16:16.232257451Z                 covariate_removed <- c(covariate_removed, i)
2025-08-01T14:16:16.232259023Z                 covariate_collapsed <- setdiff(covariate_collapsed, 
2025-08-01T14:16:16.232260640Z                   i)
2025-08-01T14:16:16.232262192Z             }
2025-08-01T14:16:16.232263694Z         }
2025-08-01T14:16:16.232265188Z     }
2025-08-01T14:16:16.232266688Z     print("Check strata variables meet covariate threshold")
2025-08-01T14:16:16.232268391Z     strata_warning <- ""
2025-08-01T14:16:16.232269970Z     if (length(intersect(covariate_removed, strata)) > 0) {
2025-08-01T14:16:16.232271631Z         strata_warning <- paste0(intersect(covariate_removed, 
2025-08-01T14:16:16.232273257Z             strata), collapse = ";")
2025-08-01T14:16:16.232274825Z         for (i in intersect(covariate_removed, strata)) {
2025-08-01T14:16:16.232276390Z             tmp <- unique(df[df$exposure_status == 1 & df$outcome_status == 
2025-08-01T14:16:16.232278058Z                 1, c("patient_id", i)])
2025-08-01T14:16:16.232279631Z             freq <- data.frame(table(tmp[, i]))
2025-08-01T14:16:16.232281200Z             print(paste0("Warning: strata variable '", i, "' does not meet covariate threshold"))
2025-08-01T14:16:16.232282995Z             print(freq)
2025-08-01T14:16:16.232284502Z         }
2025-08-01T14:16:16.232285963Z     }
2025-08-01T14:16:16.232287387Z     print("Remove covariates")
2025-08-01T14:16:16.232290951Z     df <- df[, !(colnames(df) %in% setdiff(covariate_removed, 
2025-08-01T14:16:16.232292845Z         strata))]
2025-08-01T14:16:16.232294361Z     output <- list(df = df, covariate_removed = setdiff(covariate_removed, 
2025-08-01T14:16:16.232296035Z         strata), covariate_collapsed = covariate_collapsed, strata_warning = strata_warning)
2025-08-01T14:16:16.232297714Z     return(output)
2025-08-01T14:16:16.232299197Z }
2025-08-01T14:16:16.232300641Z 
2025-08-01T14:16:16.232302136Z [[1]]$visible
2025-08-01T14:16:16.232303554Z [1] FALSE
