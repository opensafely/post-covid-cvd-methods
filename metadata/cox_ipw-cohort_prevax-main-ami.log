2025-08-01T14:16:16.232966340Z function (df, cut_points, episode_labels) 
2025-08-01T14:16:16.232975094Z {
2025-08-01T14:16:16.232977343Z     print("Calculate where follow-up occurs in study period")
2025-08-01T14:16:16.232979184Z     df$days_to_start <- as.numeric(df$fup_start - df$study_start)
2025-08-01T14:16:16.232980845Z     df$days_to_end <- as.numeric(df$fup_stop - df$study_start) + 
2025-08-01T14:16:16.232982381Z         1
2025-08-01T14:16:16.232983756Z     print("Set survival data for the exposed")
2025-08-01T14:16:16.232985222Z     print("Filter data to exposed")
2025-08-01T14:16:16.232986642Z     exposed <- df[!is.na(df$exposure), ]
2025-08-01T14:16:16.232994276Z     print("Calculate days to exposure")
2025-08-01T14:16:16.232996226Z     exposed$days_to_exp <- as.numeric(exposed$exposure - exposed$study_start)
2025-08-01T14:16:16.232997835Z     print("Put into survival format (dataset d1)")
2025-08-01T14:16:16.232999381Z     d1 <- exposed[, !(colnames(exposed) %in% c("days_to_start", 
2025-08-01T14:16:16.233000963Z         "days_to_exp", "days_to_end", "outcome_status"))]
2025-08-01T14:16:16.233002636Z     print(summary(d1))
2025-08-01T14:16:16.233005400Z     print("Put into survival format (dataset d2)")
2025-08-01T14:16:16.233007027Z     d2 <- exposed[, c("patient_id", "days_to_start", "days_to_exp", 
2025-08-01T14:16:16.233008809Z         "days_to_end", "outcome_status")]
2025-08-01T14:16:16.233010365Z     print(summary(d2))
2025-08-01T14:16:16.233011745Z     print("Put into survival format (tmerge)")
2025-08-01T14:16:16.233013232Z     exposed <- survival::tmerge(data1 = d1, data2 = d2, id = patient_id, 
2025-08-01T14:16:16.233014763Z         outcome_status = event(days_to_end, outcome_status), 
2025-08-01T14:16:16.233016244Z         tstart = days_to_start, tstop = days_to_end, exposure_status = tdc(days_to_exp))
2025-08-01T14:16:16.233017772Z     print(summary(exposed))
2025-08-01T14:16:16.233019164Z     print("Split post-exposure time for the exposed")
2025-08-01T14:16:16.233020636Z     print("Filter to post-exposure data")
2025-08-01T14:16:16.233022085Z     exposed_post <- exposed[exposed$exposure_status == 1, ]
2025-08-01T14:16:16.233023565Z     print("Format tstart and tstop")
2025-08-01T14:16:16.233025025Z     exposed_post <- dplyr::rename(exposed_post, t0 = tstart, 
2025-08-01T14:16:16.233026551Z         t = tstop)
2025-08-01T14:16:16.233028015Z     exposed_post$tstart <- 0
2025-08-01T14:16:16.233029446Z     exposed_post$tstop <- exposed_post$t - exposed_post$t0
2025-08-01T14:16:16.233030904Z     print("Implement post-exposure cut points")
2025-08-01T14:16:16.233032454Z     print(summary(exposed_post))
2025-08-01T14:16:16.233033886Z     exposed_post <- survival::survSplit(Surv(tstop, outcome_status) ~ 
2025-08-01T14:16:16.233035379Z         ., exposed_post, cut = cut_points, episode = "episode")
2025-08-01T14:16:16.233036910Z     print(summary(exposed_post))
2025-08-01T14:16:16.233038308Z     print("Account for pre-exposure time")
2025-08-01T14:16:16.233039778Z     exposed_post$tstart <- exposed_post$tstart + exposed_post$t0
2025-08-01T14:16:16.233041249Z     exposed_post$tstop <- exposed_post$tstop + exposed_post$t0
2025-08-01T14:16:16.233042722Z     exposed_post[, c("t0", "t")] <- NULL
2025-08-01T14:16:16.233044376Z     print(summary(exposed_post))
2025-08-01T14:16:16.233048495Z     print("Combine pre- and post-exposure time for the exposed")
2025-08-01T14:16:16.233050259Z     print("Filter to pre-exposure data")
2025-08-01T14:16:16.233051762Z     exposed_pre <- exposed[exposed$exposure_status == 0, ]
2025-08-01T14:16:16.233053275Z     if (nrow(exposed_pre) > 0) {
2025-08-01T14:16:16.233054732Z         print("Set pre-exposure to be episode 0")
2025-08-01T14:16:16.233056191Z         exposed_pre$episode <- 0
2025-08-01T14:16:16.233057604Z         print(summary(exposed_pre))
2025-08-01T14:16:16.233059033Z         print("Bind pre- and post-exposure time")
2025-08-01T14:16:16.233060519Z         exposed <- plyr::rbind.fill(exposed_pre, exposed_post)
2025-08-01T14:16:16.233062069Z     }
2025-08-01T14:16:16.233063432Z     else {
2025-08-01T14:16:16.233064801Z         print("No pre-exposure time so exposed = post-exposure time only")
2025-08-01T14:16:16.233066306Z         exposed <- exposed_post
2025-08-01T14:16:16.233067732Z     }
2025-08-01T14:16:16.233069050Z     print(summary(exposed))
2025-08-01T14:16:16.233070484Z     print("Set survival data for the unexposed")
2025-08-01T14:16:16.233071990Z     print("Filter data to unexposed")
2025-08-01T14:16:16.233073438Z     unexposed <- df[is.na(df$exposure), ]
2025-08-01T14:16:16.233074909Z     print("Rename variables to survival variable names")
2025-08-01T14:16:16.233076424Z     unexposed <- dplyr::rename(unexposed, tstart = "days_to_start", 
2025-08-01T14:16:16.233077942Z         tstop = "days_to_end")
2025-08-01T14:16:16.233079398Z     unexposed$exposure_status <- c(0)
2025-08-01T14:16:16.233080848Z     unexposed$episode <- c(0)
2025-08-01T14:16:16.233082319Z     unexposed$outcome_status <- as.numeric(unexposed$outcome_status)
2025-08-01T14:16:16.233083825Z     print(summary(unexposed))
2025-08-01T14:16:16.233085185Z     print("Combine exposed and unexposed individuals")
2025-08-01T14:16:16.233086714Z     exposed <- exposed[, intersect(colnames(unexposed), colnames(exposed))]
2025-08-01T14:16:16.233088202Z     unexposed <- unexposed[, intersect(colnames(unexposed), colnames(exposed))]
2025-08-01T14:16:16.233089709Z     df <- rbind(exposed, unexposed)
2025-08-01T14:16:16.233091321Z     print(summary(df))
2025-08-01T14:16:16.233092712Z     print("Add indicators for episode")
2025-08-01T14:16:16.233094211Z     for (i in 1:max(episode_labels$episode)) {
2025-08-01T14:16:16.233095638Z         preserve_cols <- colnames(df)
2025-08-01T14:16:16.233097092Z         df$tmp <- as.numeric(df$episode == i)
2025-08-01T14:16:16.233098562Z         colnames(df) <- c(preserve_cols, episode_labels[episode_labels$episode == 
2025-08-01T14:16:16.233102044Z             i, ]$time_period)
2025-08-01T14:16:16.233103633Z     }
2025-08-01T14:16:16.233105003Z     print(summary(df))
2025-08-01T14:16:16.233106436Z     return(df)
2025-08-01T14:16:16.233107864Z }
2025-08-01T14:16:16.233109230Z 
