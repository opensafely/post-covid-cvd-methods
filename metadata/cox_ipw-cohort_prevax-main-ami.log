2025-08-01T14:16:16.232310195Z function (df, time_periods, covariates, strata, age_spline, covariate_removed, 
2025-08-01T14:16:16.232311676Z     covariate_collapsed, ipw) 
2025-08-01T14:16:16.232313072Z {
2025-08-01T14:16:16.232314428Z     print("Define model formula")
2025-08-01T14:16:16.232315891Z     surv_formula <- paste0("Surv(tstart, tstop, outcome_status) ~ ", 
2025-08-01T14:16:16.232317454Z         paste(time_periods, collapse = " + "), ifelse("cov_cat_sex" %in% 
2025-08-01T14:16:16.232319082Z             colnames(df), " + cov_cat_sex", ""), ifelse(is.null(strata), 
2025-08-01T14:16:16.232320616Z             "", paste(" +", paste0("rms::strat(", strata, ")"), 
2025-08-01T14:16:16.232322243Z                 collapse = " + ")), ifelse(isTRUE(ipw), " + cluster(patient_id)", 
2025-08-01T14:16:16.232323781Z             ""))
2025-08-01T14:16:16.232325133Z     if ("cov_num_age" %in% colnames(df)) {
2025-08-01T14:16:16.232327243Z         print("Add age covariate")
2025-08-01T14:16:16.232328823Z         if (age_spline == TRUE) {
2025-08-01T14:16:16.232330224Z             print("Specify knot placement for age spline")
2025-08-01T14:16:16.232331727Z             knot_placement <- as.numeric(quantile(df$cov_num_age, 
2025-08-01T14:16:16.232335240Z                 probs = c(0.1, 0.5, 0.9)))
2025-08-01T14:16:16.232336702Z             print(paste0("Knots will be placed at: ", paste0(knot_placement, 
2025-08-01T14:16:16.232338253Z                 collapse = ", ")))
2025-08-01T14:16:16.232339683Z             surv_formula <- paste0(surv_formula, " + rms::rcs(cov_num_age, parms=knot_placement)")
2025-08-01T14:16:16.232341283Z         }
2025-08-01T14:16:16.232342654Z         else {
2025-08-01T14:16:16.232343995Z             surv_formula <- paste0(surv_formula, " + cov_num_age + cov_num_age_sq")
2025-08-01T14:16:16.232345539Z         }
2025-08-01T14:16:16.232348987Z     }
2025-08-01T14:16:16.232350554Z     print(surv_formula)
2025-08-01T14:16:16.232351960Z     print("Fit Cox model")
2025-08-01T14:16:16.232353426Z     dd <<- rms::datadist(df)
2025-08-01T14:16:16.232354897Z     withr::local_options(list(datadist = "dd", contrasts = c("contr.treatment", 
2025-08-01T14:16:16.232356466Z         "contr.treatment")))
2025-08-01T14:16:16.232357898Z     if (ipw == TRUE) {
2025-08-01T14:16:16.232359284Z         N_obs_in <- nrow(df)
2025-08-01T14:16:16.232360712Z         fit_cox_model <- rms::cph(formula = as.formula(surv_formula), 
2025-08-01T14:16:16.232362200Z             data = df, weight = df$cox_weight, method = "breslow", 
2025-08-01T14:16:16.232363788Z             surv = TRUE, x = TRUE, y = TRUE)
2025-08-01T14:16:16.232365285Z         N_obs_out <- sum(fit_cox_model$n)
2025-08-01T14:16:16.232366806Z     }
2025-08-01T14:16:16.232368210Z     else {
2025-08-01T14:16:16.232369639Z         N_obs_in <- nrow(df)
2025-08-01T14:16:16.232371096Z         fit_cox_model <- rms::cph(formula = as.formula(surv_formula), 
2025-08-01T14:16:16.232372661Z             data = df, method = "breslow", surv = TRUE, x = TRUE, 
2025-08-01T14:16:16.232374277Z             y = TRUE)
2025-08-01T14:16:16.232375723Z         N_obs_out <- sum(fit_cox_model$n)
2025-08-01T14:16:16.232377244Z     }
2025-08-01T14:16:16.232378660Z     print(fit_cox_model)
2025-08-01T14:16:16.232380120Z     print("Format results")
2025-08-01T14:16:16.232381648Z     results <- data.frame(term = names(fit_cox_model$coefficients), 
2025-08-01T14:16:16.232383243Z         lnhr = fit_cox_model$coefficients, se_lnhr = sqrt(diag(vcov(fit_cox_model))), 
2025-08-01T14:16:16.232384814Z         model = "mdl_age_sex", surv_formula = surv_formula, covariate_removed = "", 
2025-08-01T14:16:16.232386481Z         covariate_collapsed = "", obs_warning = ifelse(N_obs_in == 
2025-08-01T14:16:16.232388061Z             N_obs_out, "", paste0(N_obs_in, " observations provided. ", 
2025-08-01T14:16:16.232389660Z             N_obs_out, " observations used.")), stringsAsFactors = FALSE)
2025-08-01T14:16:16.232391285Z     row.names(results) <- NULL
2025-08-01T14:16:16.232392818Z     covariates <- setdiff(covariates, covariate_removed)
2025-08-01T14:16:16.232394373Z     if (!is.null(covariates) && length(covariates) > 0) {
2025-08-01T14:16:16.232396015Z         print("Add covariates to model formula")
2025-08-01T14:16:16.232398044Z         surv_formula_adj <- paste0(surv_formula, " + ", paste(covariates, 
2025-08-01T14:16:16.232399785Z             collapse = " + "))
2025-08-01T14:16:16.232401397Z         print(surv_formula_adj)
2025-08-01T14:16:16.232404837Z         print("Fit Cox model with covariates")
2025-08-01T14:16:16.232406720Z         dd_adj <<- rms::datadist(df)
2025-08-01T14:16:16.232408279Z         withr::local_options(list(datadist = "dd_adj", contrasts = c("contr.treatment", 
2025-08-01T14:16:16.232410015Z             "contr.treatment")))
2025-08-01T14:16:16.232411532Z         if (ipw == TRUE) {
2025-08-01T14:16:16.232413002Z             N_obs_in <- nrow(df)
2025-08-01T14:16:16.232414554Z             fit_cox_model_adj <- rms::cph(formula = as.formula(surv_formula_adj), 
2025-08-01T14:16:16.232416170Z                 data = df, weight = df$cox_weight, method = "breslow", 
2025-08-01T14:16:16.232417808Z                 surv = TRUE, x = TRUE, y = TRUE)
2025-08-01T14:16:16.232419313Z             N_obs_out <- sum(fit_cox_model$n)
2025-08-01T14:16:16.232420857Z         }
2025-08-01T14:16:16.232422289Z         else {
2025-08-01T14:16:16.232423809Z             N_obs_in <- nrow(df)
2025-08-01T14:16:16.232425281Z             fit_cox_model_adj <- rms::cph(formula = as.formula(surv_formula_adj), 
2025-08-01T14:16:16.232426821Z                 data = df, method = "breslow", surv = TRUE, x = TRUE, 
2025-08-01T14:16:16.232428407Z                 y = TRUE)
2025-08-01T14:16:16.232429754Z             N_obs_out <- sum(fit_cox_model$n)
2025-08-01T14:16:16.232431175Z         }
2025-08-01T14:16:16.232432511Z         print(fit_cox_model_adj)
2025-08-01T14:16:16.232433895Z         print("Format results")
2025-08-01T14:16:16.232435316Z         results_adj <- data.frame(term = names(fit_cox_model_adj$coefficients), 
2025-08-01T14:16:16.232436802Z             lnhr = fit_cox_model_adj$coefficients, se_lnhr = sqrt(diag(vcov(fit_cox_model_adj))), 
2025-08-01T14:16:16.232438303Z             model = "mdl_max_adj", surv_formula = surv_formula_adj, 
2025-08-01T14:16:16.232439817Z             covariate_removed = paste0(covariate_removed, collapse = ";"), 
2025-08-01T14:16:16.232441333Z             covariate_collapsed = paste0(covariate_collapsed, 
2025-08-01T14:16:16.232442786Z                 collapse = ";"), obs_warning = ifelse(N_obs_in == 
2025-08-01T14:16:16.232444305Z                 N_obs_out, "", paste0(N_obs_in, " observations provided. ", 
2025-08-01T14:16:16.232445793Z                 N_obs_out, " observations used.")), stringsAsFactors = FALSE)
2025-08-01T14:16:16.232447355Z         row.names(results_adj) <- NULL
2025-08-01T14:16:16.232448787Z         print("Bind to other results")
2025-08-01T14:16:16.232450185Z         results <- rbind(results, results_adj)
2025-08-01T14:16:16.232451672Z     }
2025-08-01T14:16:16.232453065Z     print("Return results")
2025-08-01T14:16:16.232454616Z     return(results)
2025-08-01T14:16:16.232457796Z     print(summary(results))
2025-08-01T14:16:16.232459489Z }
