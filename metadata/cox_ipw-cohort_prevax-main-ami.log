2025-08-01T14:16:16.232626972Z function (df, controls_per_case, seed = 137, sample_exposed) 
2025-08-01T14:16:16.232628727Z {
2025-08-01T14:16:16.232630154Z     print("Set seed")
2025-08-01T14:16:16.232631637Z     set.seed(seed)
2025-08-01T14:16:16.232633095Z     print("Split cases and controls")
2025-08-01T14:16:16.232634617Z     cases <- df[df$outcome_status == TRUE, ]
2025-08-01T14:16:16.232636153Z     controls <- df[df$outcome_status == FALSE, ]
2025-08-01T14:16:16.232637647Z     print(paste0("Cases: ", nrow(cases)))
2025-08-01T14:16:16.232641625Z     print(summary(cases))
2025-08-01T14:16:16.232643362Z     print(paste0("Controls: ", nrow(controls)))
2025-08-01T14:16:16.232645019Z     print(summary(controls))
2025-08-01T14:16:16.232646481Z     if (sample_exposed == TRUE) {
2025-08-01T14:16:16.232647983Z         if (nrow(cases) * controls_per_case < nrow(controls)) {
2025-08-01T14:16:16.232649593Z             print("Sample controls, including exposed control individuals")
2025-08-01T14:16:16.232651232Z             controls <- controls[sample(seq_len(nrow(controls)), 
2025-08-01T14:16:16.232652764Z                 nrow(cases) * controls_per_case, replace = FALSE), 
2025-08-01T14:16:16.232654297Z                 ]
2025-08-01T14:16:16.232655741Z             controls$cox_weight <- (nrow(df) - nrow(cases))/nrow(controls)
2025-08-01T14:16:16.232657346Z             print(paste0(nrow(controls), " controls sampled with Cox weight of ", 
2025-08-01T14:16:16.232658998Z                 controls$cox_weight[1]))
2025-08-01T14:16:16.232660477Z         }
2025-08-01T14:16:16.232661918Z         else {
2025-08-01T14:16:16.232663394Z             print("Retain all controls")
2025-08-01T14:16:16.232665006Z             controls$cox_weight <- 1
2025-08-01T14:16:16.232666642Z         }
2025-08-01T14:16:16.232668123Z     }
2025-08-01T14:16:16.232669583Z     if (sample_exposed == FALSE) {
2025-08-01T14:16:16.232671095Z         print("Separate exposed controls so they are not sampled")
2025-08-01T14:16:16.232672720Z         controls_exposed <- controls[!is.na(controls$exposure), 
2025-08-01T14:16:16.232674329Z             ]
2025-08-01T14:16:16.232675825Z         controls_exposed$cox_weight <- 1
2025-08-01T14:16:16.232677396Z         print(paste0(nrow(controls_exposed), " exposed controls"))
2025-08-01T14:16:16.232679008Z         print("Exposed controls:")
2025-08-01T14:16:16.232680493Z         print(summary(controls_exposed))
2025-08-01T14:16:16.232681963Z         print("Sample unexposed controls")
2025-08-01T14:16:16.232683525Z         controls_unexposed <- controls[is.na(controls$exposure), 
2025-08-01T14:16:16.232685076Z             ]
2025-08-01T14:16:16.232686516Z         if (nrow(cases) * controls_per_case < nrow(controls_unexposed)) {
2025-08-01T14:16:16.232688080Z             controls_unexposed <- controls_unexposed[sample(seq_len(nrow(controls_unexposed)), 
2025-08-01T14:16:16.232689709Z                 nrow(cases) * controls_per_case, replace = FALSE), 
2025-08-01T14:16:16.232691263Z                 ]
2025-08-01T14:16:16.232692675Z             controls_unexposed$cox_weight <- (nrow(df) - nrow(cases) - 
2025-08-01T14:16:16.232695849Z                 nrow(controls_exposed))/nrow(controls_unexposed)
2025-08-01T14:16:16.232697518Z             print(paste0(nrow(controls_unexposed), " unexposed controls sampled with Cox weight of ", 
2025-08-01T14:16:16.232699581Z                 controls_unexposed$cox_weight[1]))
2025-08-01T14:16:16.232701110Z             print("Unexposed controls:")
2025-08-01T14:16:16.232702579Z             print(summary(controls_unexposed))
2025-08-01T14:16:16.232704020Z             print("Add exposed control individuals back to control dataset")
2025-08-01T14:16:16.232705544Z             controls <- NULL
2025-08-01T14:16:16.232706941Z             controls <- rbind(controls_unexposed, controls_exposed)
2025-08-01T14:16:16.232708435Z             print(paste0("Controls (N=", nrow(controls), "):"))
2025-08-01T14:16:16.232709997Z             print(summary(controls))
2025-08-01T14:16:16.232711442Z         }
2025-08-01T14:16:16.232712838Z         else {
2025-08-01T14:16:16.232714169Z             print("Insufficient controls so retain all controls")
2025-08-01T14:16:16.232715698Z             rm(controls_exposed, controls_unexposed)
2025-08-01T14:16:16.232717147Z             controls$cox_weight <- 1
2025-08-01T14:16:16.232718554Z         }
2025-08-01T14:16:16.232719919Z     }
2025-08-01T14:16:16.232721252Z     print("Specify cox weight for cases")
2025-08-01T14:16:16.232722706Z     cases$cox_weight <- 1
2025-08-01T14:16:16.232724056Z     print("Recombine cases and controls")
2025-08-01T14:16:16.232725459Z     return_df <- rbind(cases, controls)
2025-08-01T14:16:16.232726902Z     return(return_df)
2025-08-01T14:16:16.232728280Z }
2025-08-01T14:16:16.232729605Z 
